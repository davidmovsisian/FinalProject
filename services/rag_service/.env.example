APP_NAME=RAG Service
APP_HOST=0.0.0.0
APP_PORT=8000

CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=property_listings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Path to local GGUF model file for llama.cpp
RAG_LLM_MODEL_PATH=/models/your-model.gguf
LLM_N_CTX=2048
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=256

TOP_K=3
