# colang2
define flow check output safety
  """
  Main output rail that audits an AI-generated property report to ensure it
  does not contain false legal claims, fabricated prices, or invented certifications.
  """
  $verdict = execute output_auditor_prompt(text=$bot_message)
  if $verdict startswith "FAIL"
    $reason = $verdict[5:].strip()
    bot say "FAIL: {$reason}"
    stop
  else
    bot say "PASS"

define subflow output_auditor_prompt
  """
  Invokes the LLM with the output auditor prompt to verify that the
  AI-generated property report is free of false claims and fabrications.
  Returns 'PASS' or 'FAIL: <reason>'.
  """
  $result = execute llm_call(prompt="You are a real estate AI output safety auditor.\n\nTASK: Review the AI-generated property report below and determine whether it contains any of the following prohibited content:\n\nPROHIBITED CONTENT:\n1. FALSE LEGAL CLAIMS -- statements that imply legal guarantees or verified legal status without evidence (e.g., 'guaranteed freehold title', 'legally verified ownership', 'court-certified clear title').\n2. FABRICATED PRICE GUARANTEES -- invented or unsupported price predictions presented as fact (e.g., 'guaranteed to sell for $500,000', 'will fetch at least $X', 'price is guaranteed to rise by X%').\n3. INVENTED CERTIFICATIONS -- certifications or accreditations stated as fact without any basis (e.g., 'ISO 9001 certified building', 'LEED Platinum certified', 'energy class A certified' when the report has no cited source for this).\n\nRULES:\n- Minor hedged opinions are acceptable (e.g., 'estimated value around $X', 'likely freehold based on listing data').\n- Only flag content that presents an unverifiable claim as established fact.\n- If multiple issues are found, list only the most critical one as the FAIL reason.\n- When in doubt, prefer PASS over a false positive.\n\nTEXT TO AUDIT:\n{text}\n\nRespond with exactly one of:\n  PASS\n  FAIL: <one-sentence reason describing the specific prohibited content found>")
  return $result
