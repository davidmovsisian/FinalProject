define flow check property listing
  """
  Main input rail that validates whether the submitted text is a genuine
  real estate / property listing written in English or Hebrew.
  Rejects spam, offensive content, and off-topic submissions.
  """
  $verdict = execute topic_detection_prompt(text=$user_message)
  if $verdict startswith "FAIL"
    $reason = $verdict[5:].strip()
    bot say "FAIL: {$reason}"
    stop
  else
    bot say "PASS"

define flow detect spam
  """
  Detects spam patterns in property listing submissions.
  Triggers FAIL with reason 'spam detected' when spam indicators are found.
  """
  if $user_message contains "click here" or $user_message contains "buy now"
    bot say "FAIL: spam detected"
    stop

define flow detect offensive content
  """
  Detects offensive or inappropriate content in submissions.
  Triggers FAIL with reason 'offensive content detected'.
  """
  if $user_message contains offensive language
    bot say "FAIL: offensive content detected"
    stop

define flow detect off topic
  """
  Detects submissions that are not related to property or real estate.
  Triggers FAIL with reason 'not a property listing'.
  """
  if not $user_message contains property terms
    bot say "FAIL: not a property listing"
    stop

define flow check language
  """
  Verifies that the submission is written in English or Hebrew.
  Triggers FAIL with reason 'unsupported language' for other languages.
  """
  $lang = execute detect_language(text=$user_message)
  if $lang != "en" and $lang != "he"
    bot say "FAIL: unsupported language — only English and Hebrew are accepted"
    stop

define subflow topic_detection_prompt
  """
  Invokes the LLM with the final Version 5 topic detection prompt to classify
  whether the provided text is a genuine real estate property listing.
  Returns 'PASS' or 'FAIL: <reason>'.
  """
  $prompt = """
You are a real estate content safety classifier.

TASK: Determine whether the text below is a genuine real estate or property listing
written in English or Hebrew. A property listing must describe a specific property
(apartment, house, office, land, villa, commercial space, etc.) and include at least
two of the following: location, price, size/area, number of rooms, property features,
contact details, or a call to action related to renting/buying/selling.

RULES:
1. Accept listings in English, Hebrew, or a natural mix of both languages.
2. Reject if the text is primarily promotional spam (unrelated links, generic offers).
3. Reject if the text contains hate speech, harassment, or offensive material.
4. Reject if the text mentions real estate terms but is clearly off-topic (e.g., a
   finance article, a news story, or a general blog post about property markets).
5. Reject if the text is in a language other than English or Hebrew.
6. Accept short but genuine listings (e.g., "2BR apartment in Tel Aviv, 5,000 NIS/mo").
7. When in doubt, lean toward PASS for borderline genuine listings.

TEXT TO CLASSIFY:
{text}

Respond with exactly one of:
  PASS
  FAIL: <one-sentence reason>
"""
  $result = execute llm_call(prompt=$prompt)
  return $result
